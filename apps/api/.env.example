# Required — Google Gemini API key for AI-powered resume analysis
GEMINI_API_KEY=

# Optional — port the Express server listens on (default: 3001)
# Railway sets PORT automatically; do not hardcode this
PORT=3001

# Optional — allowed CORS origin for the frontend (default: http://localhost:3000)
# In production, set to the frontend's public URL (e.g., https://resume.example.com)
WEB_ORIGIN=http://localhost:3000
